# Copy this to .env and fill in. Never commit .env.

# Gemini (required) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Adzuna (required for Adzuna source) — https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_API_KEY=

# Hunter.io (optional, for hiring manager email lookup)
HUNTER_API_KEY=

# Gmail SMTP for notifications (required if notify.channel=email)
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=
NOTIFY_EMAIL=your.email@gmail.com

# Telegram (optional, alternative to email)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
